# .gitignore for coding_intro
# This file tells Git which files and folders to ignore (not track).

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Streamlit
.streamlit/secrets.toml

# IDE and editor folders
.vscode/
.idea/
*.swp
*.swo

# MacOS
.DS_Store

# Windows
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.temp

# Jupyter Notebook
.ipynb_checkpoints/

# Distribution / packaging
dist/
build/
*.egg-info/
